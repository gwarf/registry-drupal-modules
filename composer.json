{
    "name": "eudch/registry-drupal-modules",
    "description": "Custom Drupal modules for EDCH",
    "type": "project",
    "require": {
        "php": ">=8.3 <8.5"
    },
    "require-dev": {
        "composer/installers": "^1.9 || ^2",
        "drupal/coder": "^9.0",
        "drupal/core-recommended": "^10",
        "mglaman/phpstan-drupal": "^2.0.13",
        "phpstan/extension-installer": "^1.4.3",
        "phpstan/phpstan": "^2.1",
        "phpstan/phpstan-strict-rules": "^2.0",
        "slevomat/coding-standard": "^8.6",
        "symfony/finder": "^6.2 || ^7.0 || ^8.0",
        "symfony/yaml": "^6.2 || ^7.0 || ^8.0"
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "allow-plugins": {
            "composer/installers": true,
            "phpstan/extension-installer": true,
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "drupal/core-composer-scaffold": false
        }
    }
}
