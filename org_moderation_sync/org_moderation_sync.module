<?php

/**
 * @file
 */

use Drupal\Core\Entity\EntityInterface;

/**
 * Implements hook_entity_presave().
 */
function org_moderation_sync_entity_presave(EntityInterface $entity) {
  // Only act on nodes of type 'organisation'.
  if ($entity->getEntityTypeId() === 'node' && $entity->bundle() === 'organisation') {

    // Check if the moderation_state field exists.
    if ($entity->hasField('moderation_state')) {
      $moderation_state = $entity->get('moderation_state')->value;

      // Log the moderation state for debugging.
      \Drupal::logger('org_moderation_sync')->notice('Detected moderation_state: @state', [
        '@state' => $moderation_state,
      ]);

      // Unpublish if set to draft.
      if ($moderation_state === 'draft') {
        $entity->setUnpublished();
        \Drupal::logger('org_moderation_sync')->notice('Node set to UNPUBLISHED due to draft state.');
      }
      // Publish if set to published.
      elseif ($moderation_state === 'published') {
        $entity->setPublished();
        \Drupal::logger('org_moderation_sync')->notice('Node set to PUBLISHED due to published state.');
      }

    }
    else {
      // Log if the field is missing.
      \Drupal::logger('org_moderation_sync')->warning('Field "moderation_state" not found on node.');
    }
  }
}
